# ============================================================================
# Cat's Pajamas Club — переменные окружения для бэкенда + Telegram-бота
# ============================================================================
# Локально: скопируйте в .env.local и заполните.
# Прод: задайте эти же переменные в Vercel → Project → Settings → Environment Variables.
# Секреты (SERVICE_ROLE, BOT_TOKEN) НИКОГДА не коммитим и не кладём в клиентский код.
# ============================================================================

# ─── Supabase ───────────────────────────────────────────────────────────────
# URL проекта и anon-ключ можно отдать клиенту (они публичные).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# SECRET — только сервер (serverless-функции). Обходит RLS. Никогда на клиент.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Telegram ───────────────────────────────────────────────────────────────
# SECRET — токен от @BotFather (/newbot). Только сервер.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Username бота без @ (для ссылок и Login Widget).
TELEGRAM_BOT_USERNAME=catspajamas_booking_bot

# Канал, подписку на который проверяем. С @ или числовой chat_id.
# Бот ОБЯЗАН быть администратором этого канала, иначе getChatMember не работает.
TELEGRAM_CHANNEL=@catspajamas_bar

# Числовые Telegram-ID администраторов через запятую (узнать у @userinfobot).
TELEGRAM_ADMIN_IDS=111111111,222222222

# Секрет для верификации вебхука Telegram (любая случайная строка).
# Передаётся как header X-Telegram-Bot-Api-Secret-Token при setWebhook.
# Актуально только в режиме вебхука (Vercel) — на VPS бот работает через
# long polling (bot-start.js) и эта переменная не используется.
TELEGRAM_WEBHOOK_SECRET=some-long-random-string

# ─── Telegram: гостевая группа отзывов («Полка воспоминаний») ───────────────
# Форум-группа, где гости оставляют отзывы текстом в отдельной теме — бот
# читает их оттуда (требует прав администратора группы + «Удаление сообщений»,
# см. GUIDE_TELEGRAM_REVIEWS.md).
TELEGRAM_REVIEWS_CHAT_ID=-1000000000000
TELEGRAM_REVIEWS_THREAD_ID=2

# ─── Telegram: приватная группа персонала (уведомления о бронях/событиях) ───
# ОТДЕЛЬНАЯ группа от гостевой выше — сюда попадают телефоны/имена гостей,
# гостям тут не место. Бот добавляется обычным участником (админ не нужен —
# только отправка сообщений + чтение своих callback_query).
# См. GUIDE_STAFF_NOTIFICATIONS.md за пошаговой инструкцией.
TELEGRAM_STAFF_CHAT_ID=-1000000000001
TELEGRAM_STAFF_BOOKINGS_THREAD_ID=2
TELEGRAM_STAFF_EVENTS_THREAD_ID=3

# Числовые Telegram-ID барменов через запятую (узнать у @userinfobot) — узкая
# роль, только кнопки «Подтвердить/Отклонить явку», без доступа к /admin.
# Админы (TELEGRAM_ADMIN_IDS) и так могут эти кнопки нажимать — сюда добавлять
# только тех, у кого НЕТ полного админского доступа.
TELEGRAM_STAFF_IDS=333333333,444444444

# ─── Публичный адрес сайта (для ссылок из бота / Mini App) ──────────────────
PUBLIC_SITE_URL=https://cats-pajamas.ru

# ─── Аналитика (опционально) ────────────────────────────────────────────────
# Публичные — попадают в клиентский бандл (Vite отдаёт в браузер только VITE_*).
# Без реальных ID аналитика НЕ грузится вообще (см. src/analytics.js) — это
# ожидаемое поведение, пока клиент не пришлёт свои счётчики.
VITE_GA_ID=
VITE_YM_ID=
