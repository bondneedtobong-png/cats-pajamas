# ============================================================================
# Cat's Pajamas Club — переменные окружения для бэкенда + Telegram-бота
# ============================================================================
# Локально: скопируйте в .env.local и заполните.
# Прод: задайте эти же переменные в Vercel → Project → Settings → Environment Variables.
# Секреты (SERVICE_ROLE, BOT_TOKEN) НИКОГДА не коммитим и не кладём в клиентский код.
# ============================================================================

# ─── Supabase ───────────────────────────────────────────────────────────────
# URL проекта и anon-ключ можно отдать клиенту (они публичные).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# SECRET — только сервер (serverless-функции). Обходит RLS. Никогда на клиент.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Telegram ───────────────────────────────────────────────────────────────
# SECRET — токен от @BotFather (/newbot). Только сервер.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Username бота без @ (для ссылок и Login Widget).
TELEGRAM_BOT_USERNAME=catspajamas_booking_bot

# Канал, подписку на который проверяем. С @ или числовой chat_id.
# Бот ОБЯЗАН быть администратором этого канала, иначе getChatMember не работает.
TELEGRAM_CHANNEL=@catspajamas_bar

# Числовые Telegram-ID администраторов через запятую (узнать у @userinfobot).
TELEGRAM_ADMIN_IDS=111111111,222222222

# Секрет для верификации вебхука Telegram (любая случайная строка).
# Передаётся как header X-Telegram-Bot-Api-Secret-Token при setWebhook.
TELEGRAM_WEBHOOK_SECRET=some-long-random-string

# ─── Публичный адрес сайта (для ссылок из бота / Mini App) ──────────────────
PUBLIC_SITE_URL=https://cats-pajamas-club.vercel.app

# ─── Аналитика (опционально) ────────────────────────────────────────────────
# Публичные — попадают в клиентский бандл (Vite отдаёт в браузер только VITE_*).
# Без реальных ID аналитика НЕ грузится вообще (см. src/analytics.js) — это
# ожидаемое поведение, пока клиент не пришлёт свои счётчики.
VITE_GA_ID=
VITE_YM_ID=
